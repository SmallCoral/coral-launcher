{
  "name": "coral-launcher",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:desktop": "tauri dev",
    "dev:web": "vite --host 127.0.0.1 --port 1420",
    "build": "tauri build",
    "build:desktop": "tauri build",
    "build:exe": "scripts\\build-exe-msvc.cmd",
    "build:exe:raw": "tauri build --no-bundle",
    "build:installer": "tauri build --bundles nsis",
    "build:web": "tsc && vite build",
    "check:win": "powershell -ExecutionPolicy Bypass -File scripts/check-windows-build.ps1",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
